{
  "name": "aadhyaraj-hrms-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json && node -e \"const fs=require('fs'); const path=require('path'); fs.mkdirSync(path.join('dist','db'), { recursive: true }); fs.copyFileSync(path.join('src','db','schema.sql'), path.join('dist','db','schema.sql'));\"",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.0",
    "express-rate-limit": "7.4.0",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "^9.7.4",
    "morgan": "1.10.0",
    "multer": "2.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.7.5",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/morgan": "1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "22.10.2",
    "tsc-alias": "^1.8.10",
    "tsx": "4.16.2",
    "typescript": "^5.5.4"
  }
}
